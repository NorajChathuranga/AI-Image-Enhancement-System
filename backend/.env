APP_NAME=AI Image Enhancer API
APP_VERSION=0.1.0
API_V1_PREFIX=/v1
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

MAX_UPLOAD_MB=10
RATE_LIMIT=10/minute
CLEANUP_HOURS=1
CLEANUP_INTERVAL_SECONDS=1800

DATABASE_URL=sqlite:///./jobs.db
TEMP_DIR=backend/temp
OUTPUT_DIR=backend/output
WEIGHTS_DIR=backend/weights

MODEL_CHECKPOINT_REALESRGAN=realesr-general-x4v3.pth
MODEL_CHECKPOINT_GFPGAN=GFPGANv1.3.pth
MODEL_AUTO_DOWNLOAD=true
MODEL_DOWNLOAD_TIMEOUT_SECONDS=600
MODEL_CHECKPOINT_REALESRGAN_URL=
MODEL_CHECKPOINT_GFPGAN_URL=
SCALE_FACTOR=4
TILE_SIZE=512
TILE_PAD=10
PRE_PAD=0
FP16_DEFAULT=true

SKIP_MODEL_LOADING=false